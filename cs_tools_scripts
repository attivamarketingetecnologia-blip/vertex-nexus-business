# nps_analyzer.py
"""
Analyze NPS survey results and generate insights
"""

import pandas as pd
import numpy as np
from textblob import TextBlob
from collections import Counter
import matplotlib.pyplot as plt

class NPSAnalyzer:
    def __init__(self, survey_data):
        self.data = pd.DataFrame(survey_data)
    
    def calculate_nps(self):
        """Calculate overall NPS score"""
        if 'score' not in self.data.columns:
            raise ValueError("Survey data must contain 'score' column")
        
        promoters = len(self.data[self.data['score'] >= 9])
        detractors = len(self.data[self.data['score'] <= 6])
        total = len(self.data)
        
        nps = ((promoters - detractors) / total) * 100
        return round(nps, 1)
    
    def segment_responses(self):
        """Segment responses into promoters, passives, detractors"""
        segments = {
            'promoters': self.data[self.data['score'] >= 9],
            'passives': self.data[(self.data['score'] >= 7) & (self.data['score'] <= 8)],
            'detractors': self.data[self.data['score'] <= 6]
        }
        return segments
    
    def analyze_feedback(self, text_column='feedback'):
        """Analyze text feedback for insights"""
        if text_column not in self.data.columns:
            return {}
        
        segments = self.segment_responses()
        insights = {}
        
        for segment_name, segment_data in segments.items():
            if text_column in segment_data.columns:
                feedback_text = ' '.join(segment_data[text_column].dropna().astype(str))
                
                # Sentiment analysis
                blob = TextBlob(feedback_text)
                sentiment = blob.sentiment.polarity
                
                # Extract common themes (simple keyword extraction)
                words = feedback_text.lower().split()
                common_words = Counter(words).most_common(10)
                
                insights[segment_name] = {
                    'count': len(segment_data),
                    'sentiment': round(sentiment, 2),
                    'common_words': common_words,
                    'sample_feedback': segment_data[text_column].head(3).tolist() if len(segment_data) > 0 else []
                }
        
        return insights
    
    def generate_report(self):
        """Generate comprehensive NPS report"""
        nps_score = self.calculate_nps()
        segments = self.segment_responses()
        insights = self.analyze_feedback()
        
        report = {
            'overall_nps': nps_score,
            'response_count': len(self.data),
            'segment_distribution': {
                'promoters': len(segments['promoters']),
                'passives': len(segments['passives']),
                'detractors': len(segments['detractors'])
            },
            'segment_percentages': {
                'promoters': round(len(segments['promoters']) / len(self.data) * 100, 1),
                'passives': round(len(segments['passives']) / len(self.data) * 100, 1),
                'detractors': round(len(segments['detractors']) / len(self.data) * 100, 1)
            },
            'insights': insights,
            'recommendations': self.generate_recommendations(segments, insights)
        }
        
