"""
Real-time customer health dashboard with alerting
"""

import pandas as pd
import numpy as np
from datetime import datetime, timedelta
import smtplib
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart

class CustomerHealthDashboard:
    def __init__(self):
        self.customers = self.load_customer_data()
        self.thresholds = {
            'green': 80,
            'yellow': 60,
            'red': 0
        }
    
    def load_customer_data(self):
        """Load customer data from database/API"""
        # This would connect to your actual data source
        # For demo purposes, returning sample data
        return pd.DataFrame({
            'customer_id': ['C001', 'C002', 'C003', 'C004', 'C005'],
            'customer_name': ['Acme Inc', 'Beta Corp', 'Gamma LLC', 'Delta Co', 'Epsilon Ltd'],
            'plan': ['Business', 'Team', 'Starter', 'Business', 'Team'],
            'active_monitors': [45, 25, 10, 48, 22],
            'plan_limit': [50, 30, 15, 50, 30],
            'weekly_logins': [5, 3, 1, 6, 2],
            'failed_monitors': [2, 5, 3, 1, 4],
            'kb_views': [8, 3, 1, 10, 2],
            'webinar_attendance': [1, 0, 0, 1, 0],
            'community_posts': [2, 0, 0, 3, 0],
            'uptime_improvement': [0.15, 0.05, 0.0, 0.20, 0.02],
            'alert_reduction': [30, 10, 0, 40, 5],
            'integrations_used': [2, 1, 0, 3, 1],
            'csat_score': [4.2, 3.8, 3.0, 4.5, 3.5],
            'nps_score': [8, 6, 4, 9, 5],
            'support_tickets': [3, 8, 12, 2, 6],
            'mrr': [299, 99, 49, 299, 99]
        })
    
    def calculate_health_score(self, row):
        """Calculate health score for a customer"""
        # Usage Score (40%)
        usage_score = (
            (row['active_monitors'] / row['plan_limit'] * 0.4) +
            (min(row['weekly_logins'] / 7, 1) * 0.3) +
            (1 - min(row['failed_monitors'] / max(row['active_monitors'], 1), 1)) * 0.3
        ) * 40
        
        # Engagement Score (30%)
        engagement_score = (
            (min(row['kb_views'] / 10, 1) * 0.4) +
            (row['webinar_attendance'] * 0.3) +
            (min(row['community_posts'] / 5, 1) * 0.3)
        ) * 30
        
        # Value Score (20%)
        value_score = (
            (row['uptime_improvement'] * 0.4) +
            (1 - min(row['alert_reduction'] / 100, 1)) * 0.3 +
            (row['integrations_used'] / 3 * 0.3)
        ) * 20
        
        # Satisfaction Score (10%)
        satisfaction_score = (
            (row['csat_score'] / 5 * 0.5) +
            ((row['nps_score'] + 100) / 200 * 0.3) +
            (1 - min(row['support_tickets'] / 10, 1)) * 0.2
        ) * 10
        
        total_score = usage_score + engagement_score + value_score + satisfaction_score
        
        return round(total_score, 1)
    
    def determine_tier(self, score):
        """Determine health tier based on score"""
        if score >= self.thresholds['green']:
            return 'Green', '💚'
        elif score >= self.thresholds['yellow']:
            return 'Yellow', '💛'
        else:
            return 'Red', '❤️'
    
    def generate_dashboard(self):
        """Generate complete health dashboard"""
        dashboard_data = []
        
        for _, row in self.customers.iterrows():
            score = self.calculate_health_score(row)
            tier, emoji = self.determine_tier(score)
            
            dashboard_data.append({
                'Customer': row['customer_name'],
                'Plan': row['plan'],
                'Health Score': score,
                'Tier': f"{emoji} {tier}",
                'MRR': f"${row['mrr']}",
                'Active Monitors': f"{row['active_monitors']}/{row['plan_limit']}",
                'Support Tickets': row['support_tickets'],
                'CSAT': row['csat_score']
            })
        
        df = pd.DataFrame(dashboard_data)
        df = df.sort_values('Health Score', ascending=False)
        
        return df
    
    def send_alerts(self):
        """Send email alerts for at-risk customers"""
        at_risk_customers = []
        
        for _, row in self.customers.iterrows():
            score = self.calculate_health_score(row)
            if score < self.thresholds['yellow']:
                at_risk_customers.append({
                    'name': row['customer_name'],
                    'score': score,
                    'mrr': row['mrr'],
                    'issues': self.identify_issues(row)
                })
        
        if at_risk_customers:
            self.send_alert_email(at_risk_customers)
    
    def identify_issues(self, row):
        """Identify specific issues for at-risk customers"""
        issues = []
        
        if row['weekly_logins'] < 2:
            issues.append(f"Low engagement ({row['weekly_logins']} logins/week)")
        
        if row['failed_monitors'] / max(row['active_monitors'], 1) > 0.2:
            issues.append(f"High failure rate ({row['failed_monitors']} failed monitors)")
        
        if row['support_tickets'] > 5:
            issues.append(f"High support volume ({row['support_tickets']} tickets)")
        
        if row['csat_score'] < 3.5:
            issues.append(f"Low satisfaction (CSAT: {row['csat_score']})")
        
        return issues
    
