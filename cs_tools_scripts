"""

import json
from datetime import datetime, timedelta
from typing import List, Dict
import calendar

class CheckInScheduler:
    def __init__(self):
        self.customers = self.load_customers()
        self.checkin_frequency = {
            'green': 90,  # days between check-ins
            'yellow': 30,
            'red': 7
        }
    
    def load_customers(self):
        """Load customer data with health scores"""
        # In production, this would come from your database
        return [
            {
                'id': 'C001',
                'name': 'Acme Inc',
                'health_score': 85,
                'tier': 'green',
                'last_checkin': '2024-01-15',
                'cs_owner': 'alice@company.com',
                'mrr': 299
            },
            {
                'id': 'C002',
                'name': 'Beta Corp',
                'health_score': 65,
                'tier': 'yellow',
                'last_checkin': '2024-02-01',
                'cs_owner': 'bob@company.com',
                'mrr': 99
            },
            {
                'id': 'C003',
                'name': 'Gamma LLC',
                'health_score': 45,
                'tier': 'red',
                'last_checkin': '2024-02-10',
                'cs_owner': 'charlie@company.com',
                'mrr': 49
            }
        ]
    
    def schedule_checkins(self, start_date=None):
        """Schedule check-ins for the next month"""
        if not start_date:
            start_date = datetime.now()
        
        schedule = {}
        
        for customer in self.customers:
            frequency = self.checkin_frequency[customer['tier']]
            last_checkin = datetime.strptime(customer['last_checkin'], '%Y-%m-%d')
            next_checkin = last_checkin + timedelta(days=frequency)
            
            # If next check-in is within next 30 days, schedule it
            if next_checkin <= start_date + timedelta(days=30):
                week_number = next_checkin.isocalendar()[1]
                day_name = calendar.day_name[next_checkin.weekday()]
                
                if week_number not in schedule:
                    schedule[week_number] = {}
                
                if day_name not in schedule[week_number]:
                    schedule[week_number][day_name] = []
                
                schedule[week_number][day_name].append({
                    'customer': customer['name'],
                    'date': next_checkin.strftime('%Y-%m-%d'),
                    'owner': customer['cs_owner'],
                    'tier': customer['tier'],
                    'mrr': customer['mrr']
                })
        
        return schedule
    
    def generate_calendar_view(self, schedule):
        """Generate calendar view of scheduled check-ins"""
        calendar_view = {}
        
        for week_num, days in schedule.items():
            calendar_view[week_num] = {}
            for day, appointments in days.items():
                calendar_view[week_num][day] = []
                for appt in appointments:
                    calendar_view[week_num][day].append(
                        f"{appt['customer']} ({appt['tier']}) - {appt['owner']}"
                    )
        
        return calendar_view
    
    def generate_email_templates(self, schedule):
        """Generate email templates for scheduled check-ins"""
        templates = []
        
        for week_num, days in schedule.items():
            for day, appointments in days.items():
                for appt in appointments:
                    template = self.create_checkin_email(appt)
                    templates.append(template)
        
        return templates
    
    def create_checkin_email(self, appointment):
        """Create personalized check-in email template"""
        tier_colors = {
            'green': '#4CAF50',
            'yellow': '#FFC107',
            'red': '#F44336'
        }
        
        template = f"""
        Subject: Checking in - {appointment['customer']} Success Review
        
        Hi [CSM Name],
        
        It's time for your scheduled check-in with {appointment['customer']}.
        
        **Appointment Details:**
        - Date: {appointment['date']}
        - Customer: {appointment['customer']}
        - Health Tier: <span style="color: {tier_colors[appointment['tier']]}">{appointment['tier'].upper()}</span>
        - MRR: ${appointment['mrr']}
        
        **Preparation Checklist:**
        1. Review recent account activity
        2. Check support ticket history
        3. Prepare success metrics
