## 2. Customer Health Score Calculator

```python
# customer_health_score.py
"""
Calculate Customer Health Score (0-100) based on:
- Usage (40%): Active monitors, alert frequency, team logins
- Engagement (30%): KB views, webinar attendance, community participation
- Value (20%): Uptime improvement, alert reduction, integration usage
- Satisfaction (10%): CSAT scores, NPS, support interactions
"""

def calculate_health_score(customer_data):
    # Usage Score (40%)
    usage_score = (
        (customer_data['active_monitors'] / customer_data['plan_limit'] * 0.4) +
        (min(customer_data['weekly_logins'] / 7, 1) * 0.3) +
        (1 - min(customer_data['failed_monitors'] / max(customer_data['total_monitors'], 1), 1)) * 0.3
    ) * 40
    
    # Engagement Score (30%)
    engagement_score = (
        (min(customer_data['kb_views'] / 10, 1) * 0.4) +
        (customer_data['webinar_attendance'] * 0.3) +
        (min(customer_data['community_posts'] / 5, 1) * 0.3)
    ) * 30
    
    # Value Score (20%)
    value_score = (
        (customer_data['uptime_improvement'] * 0.4) +
        (1 - min(customer_data['alert_reduction'] / 100, 1)) * 0.3 +
        (customer_data['integrations_used'] / 3 * 0.3)
    ) * 20
    
    # Satisfaction Score (10%)
    satisfaction_score = (
        (customer_data['csat_score'] / 5 * 0.5) +
        ((customer_data['nps_score'] + 100) / 200 * 0.3) +
        (1 - min(customer_data['support_tickets'] / 10, 1)) * 0.2
    ) * 10
    
    total_score = usage_score + engagement_score + value_score + satisfaction_score
    
    # Determine health tier
    if total_score >= 80:
        tier = "Green"
        action = "Growth opportunities"
    elif total_score >= 60:
        tier = "Yellow"
        action = "Proactive check-in needed"
    else:
        tier = "Red"
        action = "Immediate intervention required"
    
    return {
        "total_score": round(total_score, 1),
        "tier": tier,
        "action": action,
        "breakdown": {
            "usage": round(usage_score, 1),
            "engagement": round(engagement_score, 1),
            "value": round(value_score, 1),
            "satisfaction": round(satisfaction_score, 1)
        }
    }

# Example usage
customer_example = {
    'active_monitors': 45,
    'plan_limit': 50,
    'weekly_logins': 5,
    'failed_monitors': 2,
    'total_monitors': 50,
    'kb_views': 8,
    'webinar_attendance': 1,
    'community_posts': 2,
    'uptime_improvement': 0.15,  # 15% improvement
    'alert_reduction': 30,  # 30% reduction
    'integrations_used': 2,
    'csat_score': 4.2,
    'nps_score': 8,
    'support_tickets': 3
}

result = calculate_health_score(customer_example)
print(f"Health Score: {result['total_score']} ({result['tier']})")
print(f"Action: {result['action']}")
print(f"Breakdown: {result['breakdown']}")
```

