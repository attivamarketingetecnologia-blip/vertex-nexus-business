# API Monitoring MVP - Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (choose one or both)
# MongoDB
MONGODB_URI=mongodb://localhost:27017/api-monitoring

# PostgreSQL
POSTGRES_URL=postgresql://username:password@localhost:5432/api_monitoring
POSTGRES_SSL=false

# Monitoring Configuration
CHECK_INTERVAL=*/5 * * * *  # Cron schedule for automatic checks (every 5 minutes)
DEFAULT_TIMEOUT=5000        # Default timeout for endpoint checks in milliseconds
SLOW_RESPONSE_THRESHOLD=2000 # Response time threshold for slow response alerts (ms)

# Alert Configuration
ALERT_RETENTION_DAYS=30     # How long to keep resolved alerts
MAX_ALERTS_PER_ENDPOINT=10  # Maximum number of unresolved alerts per endpoint

# Security
API_RATE_LIMIT_WINDOW=15    # Rate limit window in minutes
API_RATE_LIMIT_MAX=100      # Max requests per window per IP
JWT_SECRET=your_jwt_secret_here  # For future authentication

# Logging
LOG_LEVEL=info              # error, warn, info, debug